# Just Good Grips – environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Stripe secret key (use a Restricted Key for tighter permissions)
# Obtain from: https://dashboard.stripe.com/apikeys
# For local dev/testing use your sk_test_... key.
# For production use your sk_live_... key.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe Payment Link URLs (paste these into index.html btn-buy hrefs)
# Create them at: https://dashboard.stripe.com/payment-links
STRIPE_3_PACK_LINK=https://buy.stripe.com/REPLACE_ME
STRIPE_12_PACK_LINK=https://buy.stripe.com/REPLACE_ME
